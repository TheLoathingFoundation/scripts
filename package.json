{
  "name": "tlf",
  "version": "0.0.0",
  "author": "slifty <slifty@gmail.com>",
  "homepage": "https://foundation.loathers.net",
  "license": "MIT",
  "scripts": {
    "build": "node build.mjs",
    "lint": "yarn lint:prettier && yarn lint:eslint",
    "lint:prettier": "prettier --check src/**/*.ts src/*.ts",
    "lint:eslint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/**/*.ts src/*.ts",
    "install-mafia": "create-kolmafia-script --install",
    "test": "vitest run",
    "update-participants": "node src/scripts/updateParticipants.mjs && yarn format"
  },
  "dependencies": {
    "grimoire-kolmafia": "^0.3.33",
    "kolmafia": "latest",
    "libram": "^0.11.21"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/babel__core": "^7.20.5",
    "@types/babel__preset-env": "^7.10.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "create-kolmafia-script": "latest",
    "csv-parse": "^6.1.0",
    "esbuild": "^0.27.4",
    "esbuild-plugin-babel": "^0.2.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-libram": "^0.5.3",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
